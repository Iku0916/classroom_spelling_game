<% content_for :title, "ゲームに参加する | Vocano!" %>

<div class="lobby-container" id='game_waiting' data-room-id="<%= @game_room.id %>">
  <div class="edit-card-body">
    <div class="dot-loader">
      <div class="dot"></div><div class="dot"></div><div class="dot"></div>
    </div>

    <h2 class="waiting-status">ゲームが始まるのを待っています...</h2>

    <div class="tutorial-slider">
      <div class="swiper mySwiper">
        <div class="swiper-wrapper">
          <% [["STEP 1", "step1.png", "英単語を入力して送信！<br>OK! or エンターキー"], 
              ["STEP 2", "step2.png", "正解でポイントGET！"], 
              ["STEP 3", "step3.png", "不正解はマイナス！<br>正しいスペルを確認しよう！"], 
              ["STEP 4", "step4.png", "高得点を目指そう！"]].each do |step, img, text| %>
            <div class="swiper-slide">
              <div class="slide-container">
                <span class="step-label label-purple"><%= step %></span>
                <%= image_tag img, class: "tutorial-img" %>
                <div class="instruction-box"><p><%= text.html_safe %></p></div>
              </div>
            </div>
          <% end %>
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>

    <div class="status-box">
      <p class="lobby-title">ホストが開始ボタンを押すと<br>自動的にゲームが始まります！</p>
    </div>

    <div class="tips-section">
      <span class="code-badge">準備はいい？ 🚀</span>
    </div>
  </div>
</div>

